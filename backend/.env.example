# autoMITRE — Environment Variable Configuration
# Copy this to .env and fill in your values.
# Variables marked [optional] work without configuration but enhance functionality.

# ── MISP Configuration [optional] ────────────────────────────────────────────
# Your MISP instance URL (include https://)
MISP_URL=https://your-misp-instance.com

# Your MISP automation API key (from Administration > List Auth Keys)
MISP_API_KEY=your-misp-api-key-here

# ── AlienVault OTX [optional] ─────────────────────────────────────────────────
# Free account at https://otx.alienvault.com — find your key in Settings > API
OTX_API_KEY=your-otx-api-key-here

# ── Feed Cache ────────────────────────────────────────────────────────────────
# How long to cache OSINT feed results in seconds (default: 300 = 5 minutes)
OSINT_CACHE_TTL=300

# ── Free Sources (always active — no configuration needed) ────────────────────
# Abuse.ch URLhaus: https://urlhaus.abuse.ch
# Abuse.ch MalwareBazaar: https://bazaar.abuse.ch
